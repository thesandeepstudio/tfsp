rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Stock/price/tag overrides — public storefront needs to read these,
    // only the signed-in admin can write.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Discount codes — public read so checkout can validate a code,
    // only the signed-in admin can create/edit/delete.
    match /coupons/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders contain customer PII (phone, address) — anyone can create
    // one at checkout, but only the signed-in admin can read/update/delete.
    // Creation is validated so a script can't write arbitrary garbage:
    // it must look like a real order with a name/phone and a positive total.
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(
                        ['items', 'total', 'customer', 'status']
                      )
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.total is number
                    && request.resource.data.total > 0
                    && request.resource.data.customer is map
                    && request.resource.data.customer.name is string
                    && request.resource.data.customer.name.size() > 0
                    && request.resource.data.customer.phone is string
                    && request.resource.data.customer.phone.size() > 0
                    && request.resource.data.status == 'new';
      // Anyone who already has the exact order ID (given at checkout) can
      // look up that one order to track it - but browsing/listing all
      // orders stays admin-only, so PII can't be scraped in bulk.
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
